// 1. Inisialisasi AOS (Animasi Muncul Saat Scroll)
AOS.init({ duration: 1000, once: false, mirror: true });

// 2. Custom Kursor & Spotlight
const cursor = document.getElementById('cursor');
const follower = document.getElementById('cursor-follower');
const spotlight = document.getElementById('spotlight');
const hoverTargets = document.querySelectorAll('.hover-target, .js-tilt, nav a, .btn, .skill-tag');

document.addEventListener('mousemove', (e) => {
    // Posisi kursor utama dan pengikut
    cursor.style.transform = `translate(${e.clientX - 4}px, ${e.clientY - 4}px)`;
    follower.style.transform = `translate(${e.clientX - 20}px, ${e.clientY - 20}px)`;
    
    // Update posisi cahaya latar belakang
    spotlight.style.background = `radial-gradient(circle 200px at ${e.clientX}px ${e.clientY}px, rgba(0, 210, 255, 0.07), transparent 80%)`;
});

// Efek hover pada elemen tertentu
hoverTargets.forEach(target => {
    target.addEventListener('mouseenter', () => {
        follower.style.transform += ' scale(1.5)';
        follower.style.background = 'rgba(0, 210, 255, 0.1)';
        follower.style.borderColor = 'transparent';
    });
    target.addEventListener('mouseleave', () => {
        follower.style.transform = follower.style.transform.replace(' scale(1.5)', '');
        follower.style.background = 'transparent';
        follower.style.borderColor = 'rgba(255,255,255,0.3)';
    });
});

// 3. Animasi Typewriter (Efek Mengetik)
const txtElement = document.getElementById("typewriter");
const words = [
    "Muhammad Iqbal Ramadhani.", 
    "Mahasiswa Sistem Informasi.", 
    "Agri-Tech Pioneer.", 
    "Logic System Analyst."
];
let wordIndex = 0;
let charIndex = 0;
let isDeleting = false;

function typeLoop() {
    const currentWord = words[wordIndex];
    if (isDeleting) {
        txtElement.textContent = currentWord.substring(0, charIndex - 1);
        charIndex--;
    } else {
        txtElement.textContent = currentWord.substring(0, charIndex + 1);
        charIndex++;
    }

    let typeSpeed = isDeleting ? 40 : 100;

    if (!isDeleting && charIndex === currentWord.length) {
        typeSpeed = 2500; // Jeda saat kata sudah lengkap
        isDeleting = true;
    } else if (isDeleting && charIndex === 0) {
        isDeleting = false;
        wordIndex = (wordIndex + 1) % words.length;
        typeSpeed = 500;
    }
    setTimeout(typeLoop, typeSpeed);
}
window.onload = typeLoop;

// 4. Background Particles (Animasi titik-titik melayang)
const canvas = document.getElementById('canvas-bg');
const ctx = canvas.getContext('2d');
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;
let particles = [];

class Particle {
    constructor() {
        this.x = Math.random() * canvas.width;
        this.y = Math.random() * canvas.height;
        this.size = Math.random() * 2 + 0.5;
        this.speedX = Math.random() * 0.2 - 0.1; 
        this.speedY = Math.random() * 0.2 - 0.1;
    }
    update() {
        this.x += this.speedX; this.y += this.speedY;
        if (this.x > canvas.width || this.x < 0) this.speedX *= -1;
        if (this.y > canvas.height || this.y < 0) this.speedY *= -1;
    }
    draw() { ctx.fillStyle = 'rgba(0, 210, 255, 0.3)'; ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2); ctx.fill(); }
}

function initPart() { particles = []; for (let i = 0; i < 70; i++) particles.push(new Particle()); }
function animatePart() { ctx.clearRect(0, 0, canvas.width, canvas.height); particles.forEach(p => { p.update(); p.draw(); }); requestAnimationFrame(animatePart); }
initPart(); animatePart();

// 5. Animasi Kartu 3D (Hanya untuk Desktop)
const tiltCards = document.querySelectorAll('.js-tilt');
if (window.innerWidth > 992) {
    tiltCards.forEach(card => {
        card.addEventListener('mousemove', (e) => {
            const cardRect = card.getBoundingClientRect();
            const mouseX = e.clientX - (cardRect.left + cardRect.width / 2);
            const mouseY = e.clientY - (cardRect.top + cardRect.height / 2);
            const rotateX = (-mouseY / (cardRect.height / 2)) * 10;
            const rotateY = (mouseX / (cardRect.width / 2)) * 10;
            card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
        });
        card.addEventListener('mouseleave', () => {
            card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
        });
    });
}

window.onresize = () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; initPart(); };
