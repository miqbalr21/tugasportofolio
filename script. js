document.addEventListener('DOMContentLoaded', () => {
    const text = "Mahasiswa Sistem Informasi";
    const typewriter = document.getElementById('typewriter');
    let i = 0;
    function type() {
        if (i < text.length) {
            typewriter.innerHTML += text.charAt(i);
            i++;
            setTimeout(type, 100);
        }
    }
    type();
});
