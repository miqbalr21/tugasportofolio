// Tulisan Gonta-Ganti
const words = ["Information Systems Student", "Young Agripreneur", "System Developer", "Disciplined Runner"];
let i = 0, j = 0, isDeleting = false;

function type() {
    let currentWord = words[i];
    let display = isDeleting ? currentWord.substring(0, j--) : currentWord.substring(0, j++);
    document.getElementById("typing").textContent = display;

    if (!isDeleting && j > currentWord.length) { isDeleting = true; setTimeout(type, 1500); }
    else if (isDeleting && j < 0) { isDeleting = false; i = (i + 1) % words.length; j = 0; setTimeout(type, 500); }
    else { setTimeout(type, isDeleting ? 70 : 150); }
}

// Data Detail Proyek
const projectData = {
    tani: "Sistem Pertanian Terpadu untuk budidaya cabai rawit, mencakup penjadwalan nutrisi organik dan manajemen pengolahan lahan.",
    absensi: "Sistem absensi digital real-time untuk memantau kehadiran santri di pondok pesantren melalui database terpusat.",
    kasir: "Sistem kasir dan manajemen stok (Inventory) yang dirancang untuk efisiensi transaksi di minimarket.",
    perpus: "Sistem manajemen perpustakaan untuk otomasi pendataan buku serta pencatatan peminjaman secara digital."
};

function openModal(id) {
    document.getElementById("modalBody").innerHTML = `<h3 style='color:#00f2ff;margin-bottom:10px;'>Detail Proyek</h3><p style='color:#cbd5e1;line-height:1.5;'>${projectData[id]}</p>`;
    document.getElementById("projectModal").style.display = "block";
}

function closeModal() { document.getElementById("projectModal").style.display = "none"; }

window.onclick = function(e) { if (e.target == document.getElementById("projectModal")) closeModal(); }

document.addEventListener("DOMContentLoaded", type);
