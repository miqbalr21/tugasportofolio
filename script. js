// Daftar tulisan yang akan bergantian muncul
const words = [
    "Information Systems Student", 
    "Future Tech-Farmer", 
    "C++ Enthusiast", 
    "Disciplined Runner"
];

let i = 0;
let j = 0;
let currentWord = "";
let isDeleting = false;

function type() {
    currentWord = words[i];
    const typingElement = document.getElementById("typing");
    
    if (isDeleting) {
        // Efek menghapus tulisan
        typingElement.textContent = currentWord.substring(0, j - 1);
        j--;
        if (j == 0) {
            isDeleting = false;
            i = (i + 1) % words.length; // Pindah ke kata berikutnya
        }
    } else {
        // Efek mengetik tulisan
        typingElement.textContent = currentWord.substring(0, j + 1);
        j++;
        if (j == currentWord.length) {
            isDeleting = true;
            setTimeout(type, 1500); // Jeda saat kata sudah lengkap terketik
            return;
        }
    }
    
    // Kecepatan mengetik dan menghapus
    const timer = isDeleting ? 100 : 180;
    setTimeout(type, timer);
}

// Jalankan fungsi saat halaman dibuka
document.addEventListener("DOMContentLoaded", type);
